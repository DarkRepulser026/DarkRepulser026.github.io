---
import AuthorCard from '@/components/author-card.astro'
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getAllAuthors } from '@/lib/data-utils'

const authors = await getAllAuthors()
---

<Layout class="max-w-5xl">
  <PageHead slot="head" title="Authors" />

  <Breadcrumbs items={[{ label: 'Authors', icon: 'lucide:users' }]} />

  <section class="authors-shell">
    <header class="authors-header prose not-prose">
      <h1 class="authors-title">People behind my projects and builds.</h1>
      <p class="authors-updated">Last updated: 2026-02-26</p>
    </header>

    <section class="authors-list-wrap">
      {
        authors.length > 0 ? (
          <ul class="authors-list">
            {authors.map((author, index) => (
              <li class="reveal" style={`--delay: ${120 + index * 80}ms;`}>
                <AuthorCard author={author} />
              </li>
            ))}
          </ul>
        ) : (
          <p class="authors-empty">[ NO AUTHORS FOUND ]</p>
        )
      }
    </section>
  </section>
</Layout>

<style>
  .authors-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-top: var(--space-md);
    padding-bottom: var(--space-3xl);
  }

  .authors-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .authors-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-display);
  }

  .authors-accent {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.8em;
    letter-spacing: 0;
  }

  .authors-updated {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .authors-list-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .authors-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: reveal 420ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  .authors-empty {
    font-family: 'Space Mono', monospace;
    color: var(--text-secondary);
    letter-spacing: 0.08em;
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
