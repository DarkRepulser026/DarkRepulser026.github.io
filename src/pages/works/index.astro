---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import { getCollection } from 'astro:content'

function formatPeriod(startDate?: Date, endDate?: Date) {
  const formatMonthYear = (date: Date) =>
    new Intl.DateTimeFormat('en-US', {
      month: 'short',
      year: 'numeric',
    })
      .format(date)
      .toUpperCase()

  if (startDate && endDate) {
    return `${formatMonthYear(startDate)} - ${formatMonthYear(endDate)}`
  }

  if (startDate) {
    return formatMonthYear(startDate)
  }

  return 'N/A'
}

function toShortName(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .map((part) => part[0])
    .join('')
    .slice(0, 4)
    .toUpperCase()
}

function normalizeName(name: string) {
  return name.trim().toLowerCase()
}

function toSiteLabel(href: string) {
  try {
    const { host, pathname } = new URL(href)
    return `${host}${pathname}`.replace(/\/$/, '')
  } catch {
    return href
  }
}

const projects = await getCollection('projects')
const authors = await getCollection('authors')
const authorMap = new Map(
  authors.map((author) => [normalizeName(author.data.name), author]),
)

const workItems = projects
  .sort((a, b) => {
    const dateA = a.data.startDate?.getTime() || 0
    const dateB = b.data.startDate?.getTime() || 0
    return dateB - dateA
  })
  .map((project) => {
    const credits = (project.data.credits ?? []).map((name, index) => {
      const author = authorMap.get(normalizeName(name))
      return {
        name,
        short: toShortName(name),
        avatar: author?.data.avatar,
        info: project.data.credits_info?.[index] || author?.data.role || '',
      }
    })

    return {
      id: project.id,
      name: project.data.name,
      short: toShortName(project.data.name),
      summary: project.data.description,
      period: formatPeriod(project.data.startDate, project.data.endDate),
      site: toSiteLabel(project.data.link),
      href: project.data.link,
      image: project.data.image,
      tags: project.data.tags,
      credits,
    }
  })
---

<Layout class="max-w-5xl !overflow-x-visible">
  <PageHead slot="head" title="Works" />

  <Breadcrumbs items={[{ label: 'Works', icon: 'lucide:briefcase' }]} />

  <article class="work-shell">
    <div class="work-header prose not-prose">
      <h1 class="work-title">Some works I’ve done <span class="work-accent">⊂(•‿•)つ</span></h1>
      <p class="work-updated">Last updated: 2026-04-15</p>
    </div>

    <section class="work-list" aria-label="Works register">
      {workItems.map((item, index) => (
        <div class="work-card work-card-reveal" style={`--card-index: ${index};`}>
          <Link href={`/works/${item.id}`} class="work-card-link">
            <div class="work-thumb">
              {item.image ? (
                <img src={item.image} alt={item.name} class="work-thumb-image" loading="lazy" />
              ) : (
                <span>{item.short}</span>
              )}
            </div>
            <div class="work-content">
              <h2 class="work-name">{item.name}</h2>
              <p class="work-summary">{item.summary}</p>
              <div class="work-meta">
                <span class="work-meta-item">{item.period}</span>
                <Separator orientation="vertical" className="hidden h-4! sm:block" />
                <span class="work-meta-item">{item.site}</span>
              </div>
              <div class="work-footer">
                <div class="work-tags">
                  {item.tags.map((tag) => (
                    <Badge variant="muted">{tag}</Badge>
                  ))}
                </div>
                {
                  item.credits.length > 0 && (
                    <div class="work-credits" aria-label="Credits">
                      {item.credits.map((credit) => (
                        <span class="work-credit" tabindex="0">
                          <span class="work-credit-bubble">
                            {credit.avatar ? (
                              <img
                                src={credit.avatar}
                                alt={credit.name}
                                class="work-credit-avatar"
                                loading="lazy"
                              />
                            ) : (
                              <span class="work-credit-avatar work-credit-fallback">
                                {credit.short}
                              </span>
                            )}
                          </span>
                          <span class="work-credit-tooltip">
                            {credit.info ? `${credit.name}: ${credit.info}` : credit.name}
                          </span>
                        </span>
                      ))}
                    </div>
                  )
                }
              </div>
            </div>
          </Link>
        </div>
      ))}
    </section>
  </article>
</Layout>

<style>
  .work-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-top: var(--space-md);
    padding-bottom: var(--space-3xl);
  }

  .work-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-display);
  }

  .work-accent {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.8em;
    letter-spacing: 0;
  }

  .work-updated {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    isolation: isolate;
  }

  .work-card {
    position: relative;
    z-index: 0;
    overflow: visible;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: var(--space-md);
    transition: border-color 220ms cubic-bezier(0.25, 0.1, 0.25, 1),
      background-color 220ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .work-card-reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: work-card-reveal 420ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: calc(120ms + (var(--card-index) * 80ms));
  }

  .work-card:hover {
    z-index: 8;
    background: color-mix(in oklab, var(--surface) 88%, var(--muted));
    border-color: var(--border-visible);
  }

  .work-card:focus-within {
    z-index: 10;
  }

  .work-card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
  }

  .work-thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border-visible);
    background: var(--surface-raised);
    color: var(--text-display);
    font-family: 'Space Mono', monospace;
    font-size: 1.2rem;
    letter-spacing: 0.14em;
  }

  .work-thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .work-name {
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .work-summary {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .work-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .work-credits {
    position: relative;
    z-index: 12;
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    margin-left: auto;
  }

  .work-credit {
    position: relative;
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    margin-left: -0.35rem;
    transition: transform 180ms ease;
  }

  .work-credit-bubble {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    border: 1px solid var(--border-visible);
    background: var(--surface-raised);
    overflow: hidden;
    display: inline-flex;
  }

  .work-credit:first-child {
    margin-left: 0;
  }

  .work-credit:hover,
  .work-credit:focus-visible {
    transform: translateY(-2px);
    z-index: 2;
  }

  .work-credit-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-credit-fallback {
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    padding: 0 0.2rem;
    text-align: center;
  }

  .work-credit-tooltip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.45rem);
    transform: translateX(-50%) translateY(4px);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border-visible);
    background: var(--surface);
    color: var(--text-primary);
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: opacity 150ms ease, transform 150ms ease;
    z-index: 4;
  }

  .work-credit:hover .work-credit-tooltip,
  .work-credit:focus-visible .work-credit-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 520px) {
    .work-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .work-credits {
      align-self: flex-end;
    }

    .work-credit-tooltip {
      white-space: normal;
      width: max-content;
      max-width: min(80vw, 16rem);
      text-wrap: balance;
    }
  }

  @keyframes work-card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 900px) {
    .work-card-link {
      flex-direction: row;
      align-items: stretch;
    }

    .work-thumb {
      width: min(280px, 32%);
      flex-shrink: 0;
    }

    .work-content {
      flex: 1;
      justify-content: center;
    }
  }
</style>
