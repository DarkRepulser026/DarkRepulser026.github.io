---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import { getCollection } from 'astro:content'

function formatPeriod(startDate?: Date, endDate?: Date) {
  const formatMonthYear = (date: Date) =>
    new Intl.DateTimeFormat('en-US', {
      month: 'short',
      year: 'numeric',
    })
      .format(date)
      .toUpperCase()

  if (startDate && endDate) {
    return `${formatMonthYear(startDate)} - ${formatMonthYear(endDate)}`
  }

  if (startDate) {
    return formatMonthYear(startDate)
  }

  return 'N/A'
}

function toShortName(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .map((part) => part[0])
    .join('')
    .slice(0, 4)
    .toUpperCase()
}

function toSiteLabel(href: string) {
  try {
    const { host, pathname } = new URL(href)
    return `${host}${pathname}`.replace(/\/$/, '')
  } catch {
    return href
  }
}

const projects = await getCollection('projects')

const workItems = projects
  .sort((a, b) => {
    const dateA = a.data.startDate?.getTime() || 0
    const dateB = b.data.startDate?.getTime() || 0
    return dateB - dateA
  })
  .map((project) => ({
    id: project.id,
    name: project.data.name,
    short: toShortName(project.data.name),
    summary: project.data.description,
    period: formatPeriod(project.data.startDate, project.data.endDate),
    site: toSiteLabel(project.data.link),
    href: project.data.link,
    image: project.data.image,
    tags: project.data.tags,
  }))
---

<Layout class="max-w-5xl">
  <PageHead slot="head" title="Works" />

  <Breadcrumbs items={[{ label: 'Works', icon: 'lucide:briefcase' }]} />

  <article class="work-shell">
    <div class="work-header prose not-prose">
      <h1 class="work-title">Some works I’ve done <span class="work-accent">⊂(•‿•)つ</span></h1>
      <p class="work-updated">Last updated: 2026-02-26</p>
    </div>

    <section class="work-list" aria-label="Works register">
      {workItems.map((item, index) => (
        <div class="work-card work-card-reveal" style={`--card-index: ${index};`}>
          <Link href={`/works/${item.id}`} class="work-card-link">
            <div class="work-thumb">
              {item.image ? (
                <img src={item.image} alt={item.name} class="work-thumb-image" loading="lazy" />
              ) : (
                <span>{item.short}</span>
              )}
            </div>
            <div class="work-content">
              <h2 class="work-name">{item.name}</h2>
              <p class="work-summary">{item.summary}</p>
              <div class="work-meta">
                <span class="work-meta-item">{item.period}</span>
                <Separator orientation="vertical" className="hidden h-4! sm:block" />
                <span class="work-meta-item">{item.site}</span>
              </div>
              <div class="work-tags">
                {item.tags.map((tag) => (
                  <Badge variant="muted">{tag}</Badge>
                ))}
              </div>
            </div>
          </Link>
        </div>
      ))}
    </section>
  </article>
</Layout>

<style>
  .work-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-top: var(--space-md);
    padding-bottom: var(--space-3xl);
  }

  .work-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-display);
  }

  .work-accent {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.8em;
    letter-spacing: 0;
  }

  .work-updated {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .work-card {
    border: 1px solid var(--border);
    background: var(--surface);
    padding: var(--space-md);
    transition: border-color 220ms cubic-bezier(0.25, 0.1, 0.25, 1),
      background-color 220ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .work-card-reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: work-card-reveal 420ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: calc(120ms + (var(--card-index) * 80ms));
  }

  .work-card:hover {
    background: color-mix(in oklab, var(--surface) 88%, var(--muted));
    border-color: var(--border-visible);
  }

  .work-card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
  }

  .work-thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border-visible);
    background: var(--surface-raised);
    color: var(--text-display);
    font-family: 'Space Mono', monospace;
    font-size: 1.2rem;
    letter-spacing: 0.14em;
  }

  .work-thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .work-name {
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .work-summary {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  @keyframes work-card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 900px) {
    .work-card-link {
      flex-direction: row;
      align-items: stretch;
    }

    .work-thumb {
      width: min(280px, 32%);
      flex-shrink: 0;
    }

    .work-content {
      flex: 1;
      justify-content: center;
    }
  }
</style>
