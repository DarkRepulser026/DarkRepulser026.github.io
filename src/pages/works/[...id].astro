---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { Badge } from '@/components/ui/badge'
import Layout from '@/layouts/layout.astro'
import { formatDate } from '@/lib/utils'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import { Icon } from 'astro-icon/components'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }))
}

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
const { Content } = await render(project)
---

<Layout class="max-w-5xl">
  <PageHead
    slot="head"
    title={`${project.data.name} (Works)`}
    description={project.data.description}
    noindex
  />

  <Breadcrumbs
    items={[
      { href: '/works', label: 'Works', icon: 'lucide:briefcase' },
      { label: project.data.name, icon: 'lucide:folder-kanban' },
    ]}
  />

  <article class="project-shell">
    <header class="project-header prose not-prose">
      <h1 class="project-title">{project.data.name}</h1>
      <p class="project-summary">{project.data.description}</p>

      <div class="project-meta">
        {
          project.data.startDate && (
            <span class="project-meta-item">
              <Icon name="lucide:calendar" class="size-3" />
              {formatDate(project.data.startDate)}
              {project.data.endDate ? ` -> ${formatDate(project.data.endDate)}` : ' -> Present'}
            </span>
          )
        }
        <span class="project-meta-item">
          <Icon name="lucide:link" class="size-3" />
          {project.data.link}
        </span>
      </div>

      <div class="project-actions">
        <Link href={project.data.link} external class="project-action-link">[ OPEN PROJECT ]</Link>
        <Link href="/works" class="project-action-link">[ BACK TO WORKS ]</Link>
      </div>
    </header>

    {
      project.data.image && (
        <img src={project.data.image} alt={project.data.name} class="project-image reveal" style="--delay: 120ms;" />
      )
    }

    <section class="project-tags reveal" style="--delay: 180ms;" aria-label="Project tags">
      {project.data.tags.map((tag) => (
        <Badge variant="muted">{tag}</Badge>
      ))}
    </section>

    {
      project.body && project.body.trim().length > 0 && (
        <section class="prose project-body reveal" style="--delay: 240ms;">
          <Content />
        </section>
      )
    }

    {
      (!project.body || project.body.trim().length === 0) && (
        <p class="project-empty reveal" style="--delay: 240ms;">[ NO EXTENDED PROJECT NOTES YET ]</p>
      )
    }

  </article>
</Layout>

<style>
  .project-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-top: var(--space-md);
    padding-bottom: var(--space-3xl);
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-display);
  }

  .project-summary {
    max-width: 70ch;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-action-link {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .project-image {
    width: 100%;
    border: 1px solid var(--border-visible);
    background: var(--surface-raised);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-body {
    max-width: none;
    margin-top: var(--space-xs);
  }

  .project-empty {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.08em;
  }

  .reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: reveal 420ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
