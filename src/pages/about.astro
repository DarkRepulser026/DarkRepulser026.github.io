---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="max-w-5xl">
  <PageHead slot="head" title="About" />

  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <article class="about-shell">
    <header class="about-header prose not-prose">
      <h1 class="about-title">Little more about me <span class="about-accent">(─‿‿─)</span></h1>
      <p class="about-updated">Last updated: 2026-02-26</p>
    </header>

    <section class="about-grid" aria-label="About details">
      <article class="about-panel about-panel-lead reveal" style="--delay: 80ms;">
        <ul class="about-list about-list-compact">
          <li>I am Pham Quy Gia Phuc, an Information Technology student at HUTECH University
        focused on shipping full-stack systems that stay clean in architecture,
        strict in security, and usable in day-to-day operations.</li>
        </ul>
        <div class="about-stat-grid">
          <div class="about-stat-row">
            <span>FOCUS</span>
            <strong>ARCHITECTURE / SECURITY / DELIVERY</strong>
          </div>
          <div class="about-stat-row">
            <span>STACK</span>
            <strong>NODE.JS / .NET / JAVA / POSTGRESQL</strong>
          </div>
        </div>
      </article>

      <article class="about-panel reveal" style="--delay: 160ms;">
        <p class="about-label">WORKING PRINCIPLES</p>
        <ul class="about-list">
          <li>Security by default with prepared queries, hashing, and rate limiting</li>
          <li>Separation of concerns through MVC and modular services</li>
          <li>Readable solutions first, optimization where it matters</li>
        </ul>
      </article>

      <article class="about-panel reveal" style="--delay: 240ms;">
        <p class="about-label">CONTACT VECTOR</p>
        <p class="about-contact-copy">
          Reach me directly for collaboration, project discussion, or code review.
        </p>
        <div class="about-contact-grid">
          <div class="about-contact-row">
            <span>PHONE</span>
            <strong>+84 348 757 406</strong>
          </div>
          <div class="about-contact-row">
            <span>EMAIL</span>
            <strong>PHUCPHAM2911@OUTLOOK.COM</strong>
          </div>
          <div class="about-contact-row">
            <span>LOCATION</span>
            <strong>HO CHI MINH CITY, VIETNAM</strong>
          </div>
          <div class="about-contact-row">
            <span>STATUS</span>
            <strong class="about-contact-status">GRADUATED / INTERN</strong>
          </div>
        </div>
        <div class="about-contact-links">
          <Link href="mailto:phucpham2911@outlook.com" class="contact-pill">EMAIL</Link>
          <Link href="https://github.com/DarkRepulser026" external class="contact-pill">GITHUB</Link>
        </div>
      </article>
    </section>
  </article>
</Layout>

<style>
  .about-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-top: var(--space-md);
    padding-bottom: var(--space-3xl);
  }

  .about-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .about-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-display);
  }

  .about-accent {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.8em;
    letter-spacing: 0;
  }

  .about-updated {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
  }

  .about-panel {
    border: 1px solid var(--border);
    background: var(--surface);
    padding: var(--space-md);
  }

  .reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: reveal 420ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  .about-panel-lead {
    background: var(--surface-raised);
  }

  .about-label {
    color: var(--text-secondary);
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .about-list {
    margin-top: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--text-primary);
    line-height: 1.55;
  }

  .about-list-compact {
    margin-top: var(--space-md);
  }

  .about-stat-grid {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-stat-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
    color: var(--text-primary);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-stat-row span {
    color: var(--text-secondary);
  }

  .about-contact-copy {
    margin-top: var(--space-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .about-contact-grid {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .about-contact-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 12px 0;
    border-top: 1px solid var(--border);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .about-contact-row strong {
    color: var(--text-primary);
    text-align: right;
  }

  .about-contact-status {
    color: var(--success);
  }

  .about-contact-links {
    margin-top: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .contact-pill {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-visible);
    border-radius: 999px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 0.73rem;
    letter-spacing: 0.08em;
    padding: 0 20px;
    transition: border-color 220ms cubic-bezier(0.25, 0.1, 0.25, 1),
      color 220ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .contact-pill:hover {
    color: var(--text-display);
    border-color: var(--text-primary);
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-lg);
    }

    .about-panel {
      padding: var(--space-lg);
    }

    .about-panel-lead {
      grid-column: span 2;
    }

    .about-panel:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
