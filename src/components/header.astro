---
import Link from '@/components/link.astro'
import ThemeToggle from '@/components/theme-toggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
---

<div>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <img src="/static/logo.png" alt="Logo" class="size-5 sm:size-6" />
      <span
        class="hidden h-full text-lg leading-none font-medium min-[400px]:block"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-4 sm:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground font-mono text-[0.7rem] tracking-[0.12em] uppercase transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
